# Copy this file to `.env` and fill in required values

# LLM Configuration
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# Database
# Supabase (primary): postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.zaasopywtnokbrwueupa.supabase.co:5432/postgres
